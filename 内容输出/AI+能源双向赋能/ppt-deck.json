        {"text": "全链条覆盖", "x": 1.2, "y": 3.15, "w": 5.2, "h": 0.4, "fontSize": 18, "bold": true, "color": "#B89A6A", "font": "Microsoft YaHei"},
        {"text": "覆盖\"源-网-荷-储\"全链条，从底层算力枢纽到微电网、算力园区微观单元", "x": 1.2, "y": 3.55, "w": 5.2, "h": 0.7, "fontSize": 13, "color": "#FFFFFF", "font": "Microsoft YaHei"},
