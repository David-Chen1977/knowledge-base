{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "plugin": [
    "oh-my-openagent"
  ],
  "mcp": {
    "secedgar": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/secedgar-mcp-server"],
      "enabled": true,
      "environment": {
        "EDGAR_USER_AGENT": "<请替换为你的EDGAR_USER_AGENT>"
      }
    },
    "yfinance": {
      "type": "local",
      "command": ["npx", "-y", "yfinance-mcp"],
      "enabled": true
    },
    "fred-mcp": {
      "type": "local",
      "command": ["npx", "-y", "fred-mcp-server"],
      "enabled": true,
      "environment": {
        "FRED_API_KEY": "<请替换为你的FRED_API_KEY>"
      }
    },
    "ppt-mcp": {
      "type": "local",
      "command": ["node", "/Users/Admin/.local/node/lib/node_modules/ppt-mcp/build/index.js"],
      "enabled": true
    },
    "prospector-energy": {
      "type": "local",
      "command": ["/Users/Admin/.hermes/bin/uvx", "prospector-energy-mcp"],
      "enabled": true,
      "description": "美国能源基础设施数据：47K+并网项目、ITC税收抵免、开发者情报、市场定价（免费层可用）"
    },
    "china-energy": {
      "type": "local",
      "command": ["node", "/Users/Admin/OpencodeWorkspace/tools/china-energy-mcp/src/index.js"],
      "enabled": true,
      "description": "中国能源并网数据：新能源项目、现货市场、政策、电价、投资参考数据"
    },
    "shared-workspace": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/Admin/.workbuddy/shared-workspace"],
      "enabled": true,
      "description": "AI双工具共享工作区（WorkBuddy + OpenCode）"
    }
  }
}